# ========================================
# Product Template Angular - Environment Variables
# ========================================
# Este arquivo contém todas as variáveis de ambiente necessárias.
# Copie para .env.development ou .env.production e ajuste os valores.

# API Base URL (sem trailing slash, sem versão - versionamento é por módulo)
NG_APP_API_URL=http://localhost:8080/api

# Tenant Slug (para multi-tenancy)
NG_APP_TENANT_SLUG=public

# OAuth Redirect URI (deve corresponder ao configurado no provider)
NG_APP_OAUTH_REDIRECT_URI=http://localhost:4200/auth/callback

