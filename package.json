{
  "name": "product-template-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "dotenv -e .env.development -- ng serve",
    "start:prod": "dotenv -e .env.production -- ng serve --configuration production",
    "build": "dotenv -e .env.production -- ng build",
    "build:dev": "dotenv -e .env.development -- ng build --configuration development",
    "watch": "dotenv -e .env.development -- ng build --watch --configuration development",
    "test": "ng test",
    "test:env": "node scripts/test-env-validation.js",
    "review": "node scripts/code-review.js",
    "review:all": "find src/app -name '*.ts' -not -name '*.spec.ts' -exec node scripts/code-review.js {} \\;"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@swimlane/ngx-charts": "^23.1.0",
    "lucide-angular": "^0.577.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "autoprefixer": "^10.4.27",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "zod": "^4.3.6"
  }
}
